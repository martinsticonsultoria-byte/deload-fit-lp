<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<!-- 578px em 20px Arial: cabe nos ~600px que o Google mostra, com folga de 22px.
     Com "Único" dava 635px e o resultado de busca cortava em "…| Teste". -->
<title>{{ seo.title }}</title>
<meta name="description" content="{{ seo.description }}"/>
<link rel="canonical" href="{{ seo.site_url }}"/>
<meta property="og:type" content="website"/>
<meta property="og:site_name" content="{{ seo.organization.name }}"/>
<meta property="og:locale" content="pt_BR"/>
<meta property="og:url" content="{{ seo.site_url }}"/>
<meta property="og:title" content="{{ seo.og_title }}"/>
<meta property="og:description" content="{{ seo.og_description }}"/>
<meta property="og:image" content="{{ seo.site_url }}{{ seo.og_image }}"/>
<meta property="og:image:secure_url" content="{{ seo.site_url }}{{ seo.og_image }}"/>
<meta property="og:image:type" content="image/jpeg"/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>
<meta property="og:image:alt" content="{{ seo.og_image_alt }}"/>
<script>document.documentElement.classList.add('js');</script>
<link rel="icon" type="image/svg+xml" href="assets/brand/deload-icon-dark-bg.svg"/>
