<!-- schema.org — gerado a partir dos mesmos dados da página, então preço e
     FAQ nunca ficam diferentes do que o Google lê -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "{{ seo.site_url }}#organizacao",
  "name": "{{ seo.organization.name }}",
  "legalName": "{{ seo.organization.legal_name }}",
  "taxID": "{{ seo.organization.tax_id }}",
  "url": "{{ seo.site_url }}",
  "logo": {
    "@type": "ImageObject",
    "url": "{{ seo.site_url }}{{ seo.organization.logo }}",
    "width": {{ seo.organization.logo_width }},
    "height": {{ seo.organization.logo_height }}
  },
  "image": "{{ seo.site_url }}{{ seo.og_image }}",
  "contactPoint": [{
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": "{{ seo.organization.email }}",
    "telephone": "{{ seo.organization.phone }}",
    "areaServed": "BR",
    "availableLanguage": ["pt-BR"]
  }]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": "{{ seo.site_url }}#software",
  "name": "{{ seo.organization.name }}",
  "applicationCategory": "HealthApplication",
  "operatingSystem": "Web, iOS, Android",
  "url": "{{ seo.site_url }}",
  "inLanguage": "pt-BR",
  "description": "{{ seo.software_description }}",
  "publisher": { "@id": "{{ seo.site_url }}#organizacao" },
  "screenshot": "{{ seo.site_url }}{{ seo.og_image }}",
  "offers": [
{% for plan in planos.plans %}
{% set anualTotal = plan.anual * 12 %}
{% set limiteTexto = plan.limit_prefix + " " + plan.limit_strong if plan.limit_prefix else plan.limit_strong %}
    {
      "@type": "Offer",
      "name": "{{ plan.tier }}",
      "category": "{{ plan.tagline }}",
      "description": "{{ limiteTexto }}. R$ {{ plan.anual|brl }} por mês na assinatura anual (R$ {{ anualTotal|brl }} cobrados uma vez no ano) ou R$ {{ plan.mensal|brl }} no mês a mês, sem fidelidade. 7 dias grátis, sem cartão.",
      "price": "{{ plan.anual }}",
      "priceCurrency": "BRL",
      "url": "{{ seo.site_url }}?plano={{ plan.tier|lower }}",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "{{ plan.anual }}",
        "priceCurrency": "BRL",
        "referenceQuantity": { "@type": "QuantitativeValue", "value": 1, "unitCode": "MON" }
      }
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}
</script>
<script type="application/ld+json">
