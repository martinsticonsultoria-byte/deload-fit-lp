{% set mqWords = ["Ingestão energética","Gasto calórico","Adesão","Antropometria","Volume de treino","Sono","Perda de peso estimada","Pressão arterial"] %}
{% macro marquee() %}
<!-- esteira decorativa — repete a mesma lista de termos duas vezes para o
     loop infinito não deixar buraco. Não fica no CMS: é atmosfera visual,
     não texto de marketing. -->
<div class="marquee-belt" role="presentation" aria-hidden="true">
<div class="marquee-belt-mask">
<div class="marquee-belt-track">
<div class="mq-group">
{% for w in mqWords %}<span class="mq-word">{{ w }}</span><span class="mq-dot">·</span>
{% endfor %}</div>
<div class="mq-group">
{% for w in mqWords %}<span class="mq-word">{{ w }}</span><span class="mq-dot">·</span>
{% endfor %}</div>
</div>
</div>
</div>
{% endmacro %}
{{ marquee() }}
<!-- ciclo (segunda dobra) -->
<section class="section" id="recursos">
<div class="section-sep"></div>
<div class="container">
<div class="ciclo-inner">
<div class="ciclo-left reveal">
<span class="section-label">{{ ciclo.label }}</span>
<h2>{{ ciclo.title }} <span class="text-gradient">{{ ciclo.title_gradient }}</span></h2>
<p class="ciclo-lead">{{ ciclo.lead }}</p>
<p class="ciclo-lead-accent">{{ ciclo.lead_accent }}</p>
<button class="btn-hero-primary ciclo-cta" data-cta="ciclo">{{ ciclo.cta }}<svg class="icon" aria-hidden="true"><use href="#i-arrow-right"/></svg></button>
<div class="ciclo-nav-row">
<span class="ciclo-counter" id="cicloCounter">01 / {{ ciclo.cards.length|pad2 }}</span>
<div class="ciclo-arrows">
<button class="ciclo-nav" id="cicloPrev" aria-label="Card anterior"><svg class="icon" aria-hidden="true"><use href="#i-chevron-left"/></svg></button>
<button class="ciclo-nav" id="cicloNext" aria-label="Próximo card"><svg class="icon" aria-hidden="true"><use href="#i-chevron-right"/></svg></button>
</div>
</div>
</div>
<div class="ciclo-right stagger-up">
<div class="showcase-track" id="cicloTrack" tabindex="0" aria-label="Etapas do ciclo de atendimento">
{% for card in ciclo.cards %}
<article class="showcase-card reveal-child">
<div class="sc-header"><div class="sc-live-dot"></div><span class="sc-step">Passo {{ loop.index|pad2 }}</span><span class="sc-tag">{{ card.tag }}</span></div>
<div class="sc-img-wrap"><img src="{{ card.image }}" alt="{{ card.alt }}" loading="lazy"/></div>
<div class="sc-body">
<h3>{{ card.title }}</h3>
<p>{{ card.text }}</p>
</div>
<div class="sc-num" aria-hidden="true">{{ loop.index|pad2 }}</div>
</article>
{% endfor %}
</div>
</div>
</div>
</div>
</section>
{{ marquee() }}
<!-- contraste -->
<section class="section" id="contraste">
<div class="section-sep"></div>
<div class="container">
<div class="section-header reveal">
<span class="section-label">{{ contraste.label }}</span>
<h2>{{ contraste.title_line1 }}<br/>{{ contraste.title_line2_prefix }}<span class="text-gradient">{{ contraste.title_line2_gradient }}</span></h2>
</div>
<div class="vs-setup reveal">
<span class="vs-setup-rule" aria-hidden="true"></span>
<p class="vs-setup-text">{{ contraste.setup_pre }}<strong>{{ contraste.setup_strong }}</strong>{{ contraste.setup_post }}</p>
</div>
<div class="vs-panel reveal">
<div class="vs-cols">
<div class="vs-col vs-col-them">
<div class="vs-col-inner">
<div class="vs-col-head"><span class="vs-col-tag">{{ contraste.col_before_tag }}</span></div>
<ul class="vs-list">
{% for row in contraste.before %}
<li><span class="vs-ico"><svg class="icon" aria-hidden="true"><use href="#i-{{ row.icon }}"/></svg></span><span class="vs-txt"><span class="vs-a">{{ row.a }}</span> <span class="vs-arrow">→</span> <span class="vs-b">{{ row.b }}</span></span></li>
{% endfor %}
</ul>
</div>
</div>
<div class="vs-badge" aria-hidden="true"><span>vs</span></div>
<div class="vs-col vs-col-you">
<div class="vs-col-inner">
<div class="vs-col-head vs-col-head-you"><span class="vs-col-tag">{{ contraste.col_after_tag }}</span></div>
<ul class="vs-list">
{% for row in contraste.after %}
<li><span class="vs-ico"><svg class="icon" aria-hidden="true"><use href="#i-{{ row.icon }}"/></svg></span><span class="vs-txt"><span class="vs-a">{{ row.a }}</span> <span class="vs-arrow">→</span> <span class="vs-b">{{ row.b }}</span></span></li>
{% endfor %}
</ul>
</div>
</div>
</div>
<div class="vs-close">
<p class="vs-close-strong">{{ contraste.close_strong }}</p>
<p class="vs-close-sub">{{ contraste.close_sub }}</p>
<button class="btn-hero-primary" data-cta="contraste">{{ contraste.cta }}<svg class="icon" aria-hidden="true"><use href="#i-arrow-right"/></svg></button>
</div>
</div>
</div>
</section>
<!-- diferenciais -->
<section class="section" id="diferenciais">
<div class="section-sep"></div>
<div class="container">
<div class="intel-panel reveal">
<div class="intel-head">
<div class="intel-head-copy">
<div class="intel-eyebrow"><span class="intel-num">{{ diferenciais.eyebrow_num }}</span><span class="intel-kicker">{{ diferenciais.eyebrow_kicker }}</span></div>
<h2 class="intel-title">{{ diferenciais.title }}<span class="intel-title-dim">{{ diferenciais.title_dim }}</span></h2>
<p class="intel-lead">{{ diferenciais.lead }}</p>
</div>
<button class="btn-hero-primary intel-cta" data-cta="diferenciais">{{ diferenciais.cta }}<svg class="icon" aria-hidden="true"><use href="#i-arrow-right"/></svg></button>
</div>
<div class="intel-grid" id="intelGrid">

<!-- 1 · projeção de perda de peso — a curva do gráfico é decorativa e fixa;
     só o número e as legendas abaixo dela são editáveis -->
<article class="icard">
<div class="icard-glow"></div><div class="icard-dots"></div>
<div class="icard-top">
<h3 class="icard-title">{{ diferenciais.card_perda.title }}</h3>
<p class="icard-sub">{{ diferenciais.card_perda.sub }}</p>
</div>
<div class="icard-chart">
<span class="icard-badge ia-scale" style="--ia-delay:.8s"><span data-counter-target="{{ diferenciais.card_perda.valor_kg }}" data-counter-decimals="1" data-counter-prefix="−" data-counter-suffix=" kg">−{{ diferenciais.card_perda.valor_kg|pt }} kg</span></span>
<svg viewBox="0 0 100 50" preserveAspectRatio="none" aria-hidden="true">
<defs><linearGradient id="intelArea" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3B97E3" stop-opacity="0.22"/><stop offset="100%" stop-color="#3B97E3" stop-opacity="0"/></linearGradient></defs>
<path d="M0 12 L100 12" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4 4" stroke-width="1" vector-effect="non-scaling-stroke"/>
<path d="M0 32 L100 32" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4 4" stroke-width="1" vector-effect="non-scaling-stroke"/>
<path class="ia-fade" style="--ia-delay:.1s" d="M0 8 C 20 10, 32 18, 50 24 C 70 31, 82 36, 100 42 V 50 H 0 Z" fill="url(#intelArea)"/>
<path d="M0 11 C 22 15, 34 22, 52 29 C 72 36, 84 40, 100 46" fill="none" stroke="rgba(255,255,255,0.26)" stroke-width="1.5" stroke-dasharray="5 5" vector-effect="non-scaling-stroke"/>
<path class="ia-draw" d="M0 8 C 20 10, 32 18, 50 24 C 70 31, 82 36, 100 42" fill="none" stroke="#3B97E3" stroke-width="2" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
</svg>
<div class="icard-legend"><span><i class="lg-dash"></i>{{ diferenciais.card_perda.legenda_previsto }}</span><span><i class="lg-solid"></i>{{ diferenciais.card_perda.legenda_real }}</span></div>
</div>
</article>

<!-- 2 · perfil clínico (card alto) — o hexágono e os eixos (Dieta, Treino,
     Sono, Pressão, Exames, Medidas) ficam fixos: a posição de cada palavra
     é calculada para o desenho, mudar o texto sem mudar a posição desalinha -->
<article class="icard icard-tall">
<div class="icard-glow"></div><div class="icard-dots"></div>
<div class="icard-top">
<h3 class="icard-title">{{ diferenciais.card_perfil.title }}</h3>
<p class="icard-sub">{{ diferenciais.card_perfil.sub }}</p>
</div>
<div class="icard-radar">
<svg viewBox="0 0 300 300" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
<defs>
<filter id="intelGlow" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
<linearGradient id="intelRadarA" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#5FAEEA"/><stop offset="100%" stop-color="#2A7BC2"/></linearGradient>
<linearGradient id="intelRadarB" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#9BD2F7"/><stop offset="100%" stop-color="#3B97E3"/></linearGradient>
</defs>
<g fill="none" stroke="#fff" stroke-opacity="0.10" stroke-dasharray="3 3" stroke-width="1">
<circle class="ia-scale" style="--ia-delay:.1s" cx="150" cy="150" r="22"/>
<circle class="ia-scale" style="--ia-delay:.2s" cx="150" cy="150" r="44"/>
<circle class="ia-scale" style="--ia-delay:.3s" cx="150" cy="150" r="66"/>
<circle class="ia-scale" style="--ia-delay:.4s" cx="150" cy="150" r="88"/>
<circle class="ia-scale" style="--ia-delay:.5s" cx="150" cy="150" r="110"/>
</g>
<g class="ia-fade" style="--ia-delay:.3s" stroke="#fff" stroke-opacity="0.13" stroke-width="1">
<line x1="150" y1="150" x2="150" y2="40"/><line x1="150" y1="150" x2="245" y2="95"/><line x1="150" y1="150" x2="245" y2="205"/>
<line x1="150" y1="150" x2="150" y2="260"/><line x1="150" y1="150" x2="55" y2="205"/><line x1="150" y1="150" x2="55" y2="95"/>
</g>
<g class="radar-label ia-fade" style="--ia-delay:.4s" text-anchor="middle" dominant-baseline="middle">
<text x="150" y="24">Dieta</text><text x="266" y="84">Treino</text><text x="266" y="216">Sono</text>
<text x="150" y="279">Pressão</text><text x="34" y="216">Exames</text><text x="34" y="84">Medidas</text>
</g>
<path class="ia-draw" style="--ia-delay:.3s" d="M150 95 L192 126 L180 168 L150 180 L114 171 L107 125 Z" fill="none" stroke="url(#intelRadarA)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" stroke-opacity="0.55"/>
<path class="ia-draw" style="--ia-delay:.6s" d="M150 50 L232 102 L221 191 L150 238 L70 196 L65 101 Z" fill="none" stroke="url(#intelRadarB)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" filter="url(#intelGlow)"/>
</svg>
<div class="icard-legend icard-legend-center">
<span><i class="lg-dot lg-dot-a"></i>{{ diferenciais.card_perfil.legenda_a }}</span><span><i class="lg-dot lg-dot-b"></i>{{ diferenciais.card_perfil.legenda_b }}</span>
</div>
</div>
</article>

<!-- 3 · adesão -->
<article class="icard">
<div class="icard-glow"></div><div class="icard-dots"></div>
<div class="icard-top">
<h3 class="icard-title">{{ diferenciais.card_adesao.title }}</h3>
<p class="icard-sub">{{ diferenciais.card_adesao.sub }}</p>
</div>
<div class="icard-orbit">
<span class="orbit-sq orbit-sq-1 ia-spin"></span>
<span class="orbit-sq orbit-sq-2 ia-spin-rev"></span>
<span class="orbit-tile ia-scale"><span data-counter-target="{{ diferenciais.card_adesao.valor_percentual }}" data-counter-suffix="%">{{ diferenciais.card_adesao.valor_percentual }}%</span></span>
</div>
</article>

<!-- 4 · exames -->
<article class="icard icard-end">
<div class="icard-glow"></div><div class="icard-dots"></div>
<div class="icard-ghost">
<div class="ghost-wrap ia-fade">
<span class="ghost-num"><span data-counter-target="{{ diferenciais.card_exames.valor_ldl }}">{{ diferenciais.card_exames.valor_ldl }}</span></span>
<span class="ghost-bar ia-width" style="--ia-w:100%"></span>
</div>
<span class="ghost-unit">{{ diferenciais.card_exames.unidade }}</span>
</div>
<div class="icard-top">
<h3 class="icard-title">{{ diferenciais.card_exames.title }}</h3>
<p class="icard-sub">{{ diferenciais.card_exames.sub }}</p>
</div>
</article>

<!-- 5 · adesão por módulo -->
{% set barColors = ["#5FAEEA","#3B97E3","#2F86D0","#2A7BC2","#256BA8"] %}
<article class="icard icard-end">
<div class="icard-glow"></div><div class="icard-dots"></div>
<div class="icard-bars">
<div class="bars-head">
<h4>{{ diferenciais.card_barras.titulo_grafico }}</h4>
<span class="bars-pill">{{ diferenciais.card_barras.periodo }}<svg class="icon" aria-hidden="true"><use href="#i-chevron-down"/></svg></span>
</div>
<div class="bars-list">
{% for item in diferenciais.card_barras.itens %}
<div class="bar-row"><span class="bar-name">{{ item.nome }}</span><span class="bar-track"><i class="ia-width" style="--ia-w:{{ item.percentual }}%;--ia-delay:.{{ loop.index }}s;--ia-c:{{ barColors[loop.index0 % barColors.length] }}"></i></span><span class="bar-val ia-fade" style="--ia-delay:.{{ loop.index }}s">{{ item.percentual }}%</span></div>
{% endfor %}
</div>
</div>
<div class="icard-top">
<h3 class="icard-title">{{ diferenciais.card_barras.title }}</h3>
<p class="icard-sub">{{ diferenciais.card_barras.sub }}</p>
</div>
</article>

</div>
</div>
</div>
</section>
<!-- app do paciente -->
<section class="section" id="app">
<div class="section-sep"></div>
<div class="container">
<div class="ciclo-inner">
<div class="ciclo-left reveal">
<span class="section-label">{{ app.label }}</span>
<h2>{{ app.title }} <span class="text-gradient">{{ app.title_gradient }}</span></h2>
<p class="ciclo-lead">{{ app.lead }}</p>
<p class="ciclo-lead-accent">{{ app.lead_accent }}</p>
<button class="btn-hero-primary ciclo-cta" data-cta="app">{{ app.cta }}<svg class="icon" aria-hidden="true"><use href="#i-arrow-right"/></svg></button>
<div class="ciclo-nav-row">
<span class="ciclo-counter" id="appCounter">01 / {{ app.cards.length|pad2 }}</span>
<div class="ciclo-arrows">
<button class="ciclo-nav" id="appPrev" aria-label="Tela anterior"><svg class="icon" aria-hidden="true"><use href="#i-chevron-left"/></svg></button>
<button class="ciclo-nav" id="appNext" aria-label="Próxima tela"><svg class="icon" aria-hidden="true"><use href="#i-chevron-right"/></svg></button>
</div>
</div>
</div>
<div class="ciclo-right stagger-up">
<div class="showcase-track" id="appTrack" tabindex="0" aria-label="Telas do app do paciente">
{% for card in app.cards %}
<article class="showcase-card reveal-child">
<div class="sc-header"><div class="sc-live-dot"></div><span class="sc-step">{{ card.category }}</span><span class="sc-tag">{{ card.tag }}</span></div>
<div class="sc-img-wrap"><img src="{{ card.image }}" alt="{{ card.alt }}" loading="lazy"/></div>
<div class="sc-body">
<h3>{{ card.title }}</h3>
<p>{{ card.text }}</p>
</div>
<div class="sc-num" aria-hidden="true">{{ loop.index|pad2 }}</div>
</article>
{% endfor %}
</div>
</div>
</div>
<div class="app-close reveal">
<p class="app-quote">{{ app.quote_pre }}<span class="text-gradient">{{ app.quote_gradient }}</span></p>
<div class="store-badges">
<a class="store-badge" href="#" data-link="appStore" aria-label="Disponível na App Store"><img class="store-mark" src="assets/brand/badge-apple.png" alt="" aria-hidden="true"/><span><small>Disponível na</small><b>App Store</b></span></a>
<a class="store-badge" href="#" data-link="playStore" aria-label="Disponível no Google Play"><img class="store-mark" src="assets/brand/badge-play.png" alt="" aria-hidden="true"/><span><small>Disponível no</small><b>Google Play</b></span></a>
</div>
</div>
</div>
</section>
<!-- garantia -->
<section class="section" id="garantia">
<div class="section-sep"></div>
<div class="container">
<div class="garantia-band reveal">
<div class="garantia-icon"><svg class="icon" aria-hidden="true"><use href="#i-shield-check"/></svg></div>
<h2>{{ garantia.title }}<span class="text-gradient">{{ garantia.title_gradient }}</span></h2>
<p>{{ garantia.text }}</p>
</div>
</div>
</section>
<!-- planos -->
<section class="section" id="planos">
<div class="section-sep"></div>
<div class="container">
<div class="section-header reveal">
<span class="section-label">{{ planos.label }}</span>
<h2>{{ planos.title }}<span class="text-gradient">{{ planos.title_gradient }}</span></h2>
<p>{{ planos.subtitle }}</p>
</div>
<div class="pricing-toggle reveal">
<span class="toggle-label">{{ planos.toggle_mensal }}</span>
<div class="toggle-switch on" id="billingToggle" role="switch" aria-checked="true" tabindex="0" aria-label="Alternar entre cobrança mensal e anual"><div class="toggle-knob"></div></div>
<span class="toggle-label">{{ planos.toggle_anual }}</span>
<span class="toggle-badge">{{ planos.toggle_badge }}</span>
</div>
<div class="pricing-grid stagger-up">
{% for plan in planos.plans %}
{% set anualTotal = plan.anual * 12 %}
{% set mensalTotal = plan.mensal * 12 %}
{% set economia = mensalTotal - anualTotal %}
<div class="pricing-card{% if plan.featured %} featured{% endif %} reveal-child">
{% if plan.badge %}<div class="pricing-popular-badge"><svg class="icon" aria-hidden="true"><use href="#i-star"/></svg>{{ plan.badge }}</div>{% endif %}
<p class="pricing-tier">{{ plan.tier }}</p>
<p class="pricing-tagline">{{ plan.tagline }}</p>
<div class="pricing-price"><sup>R$</sup><span class="price-val" data-anual="{{ plan.anual|brl }}" data-mensal="{{ plan.mensal|brl }}">{{ plan.anual|brl }}</span><span class="price-per">/mês</span></div>
<p class="pricing-price-note note-anual">Cobrado R$ {{ anualTotal|brl }} uma vez no ano · <b>você economiza R$ {{ economia|brl }}</b></p>
<p class="pricing-price-note note-mensal">Cobrado mensalmente · sem fidelidade</p>
<ul class="pricing-features">
<li class="pricing-feature pf-strong"><svg class="icon pricing-check" aria-hidden="true"><use href="#i-users"/></svg>{% if plan.limit_prefix %}{{ plan.limit_prefix }} <b>&nbsp;{{ plan.limit_strong }}</b>{% else %}<b>{{ plan.limit_strong }}</b>{% endif %}</li>
{% for feat in plan.features %}
<li class="pricing-feature"><svg class="icon pricing-check" aria-hidden="true"><use href="#i-check"/></svg>{{ feat.text }}</li>
{% endfor %}
</ul>
<button class="pricing-cta {% if plan.featured %}pricing-cta-solid{% else %}pricing-cta-ghost{% endif %}" data-cta="plano-{{ plan.tier|lower }}">{{ plan.cta }}</button>
</div>
{% endfor %}
</div>
<div class="pricing-note reveal">
<svg class="icon" aria-hidden="true"><use href="#i-info"/></svg>
<p>{{ planos.note }}</p>
</div>
</div>
</section>
<!-- dúvidas -->
<section class="section" id="duvidas">
<div class="section-sep"></div>
<div class="container">
<div class="section-header reveal">
<span class="section-label">{{ duvidas.label }}</span>
<h2>{{ duvidas.title }}<span class="text-gradient">{{ duvidas.title_gradient }}</span></h2>
</div>
<div class="faq-list reveal" id="faqList">
{% for item in duvidas.items %}
<div class="faq-item">
<button class="faq-q" aria-expanded="false">{{ item.question }}<svg class="icon" aria-hidden="true"><use href="#i-plus"/></svg></button>
<div class="faq-a"><div class="faq-a-inner"><p>{{ item.answer }}</p></div></div>
</div>
{% endfor %}
</div>
</div>
</section>
<!-- cta final -->
<section id="cta-section">
<div class="container" style="position:relative;z-index:1">
<div class="reveal">
<span class="section-label">{{ ctafinal.label }}</span>
<h2 class="cta-title">{{ ctafinal.title_line1 }}<br/><span class="text-gradient">{{ ctafinal.title_gradient }}</span></h2>
<p class="cta-sub">{{ ctafinal.sub }}</p>
<div class="cta-buttons">
<button class="btn-cta-primary" data-cta="cta-final"><svg class="icon" aria-hidden="true"><use href="#i-rocket"/></svg>{{ ctafinal.cta_primary }}</button>
<a class="btn-cta-ghost" href="#planos"><svg class="icon" aria-hidden="true"><use href="#i-layers"/></svg>{{ ctafinal.cta_ghost }}</a>
</div>
</div>
</div>
</section>
